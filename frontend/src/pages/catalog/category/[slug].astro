---
import { CatalogPage } from "../../../components/CatalogPage";
import { loadCatalogCategories, loadCatalogListing } from "../../../lib/catalog-api";
import GlobalPreloader from "../../../components/GlobalPreloader.astro";
import { buildKeywordsFromTitleAndDescription, normalizeSeoText, truncateSeoDescription } from "../../../lib/seo";
import "../../../styles/global.css";

export const prerender = false;

const slug = Astro.params.slug ?? "";
const categories = await loadCatalogCategories().catch(() => []);
const landingCategoryNames: Record<string, string> = {
  "dizayn-radiatory": "Дизайн-радиаторы",
  "mobilnye-konditsionery": "Мобильные кондиционеры",
  "osushiteli-vozdukha": "Осушители воздуха",
  "uvlazhniteli-i-ochistiteli-vozdukha": "Увлажнители и очистители воздуха",
  "vodonagrevateli": "Водонагреватели",
  "bytovaya-pritochnaya-ventilyatsiya": "Бытовая приточная вентиляция",
  "split-sistemy": "Сплит-системы",
  "radiatory-otopleniya": "Радиаторы отопления",
  "teplovye-pushki": "Тепловые пушки",
  "konvektory": "Конвекторы",
  "kaminy": "Камины",
  "teplye-poly-elektricheskie": "Теплые полы электрические",
  "promyshlennye-ventilyatory": "Промышленные вентиляторы",
  "gazovye-obogrevateli": "Газовые обогреватели",
  "umnyy-dom": "Умный дом",
  "teploventilyatory": "Тепловентиляторы",
  "vytyazhnye-bytovye-ventilyatory": "Вытяжные бытовые вентиляторы",
  "sushilki-dlya-ruk": "Сушилки для рук",
};

const categoryNameFromDb = categories.find((item) => item.slug === slug)?.name ?? "";
const categorySeo = categories.find((item) => item.slug === slug) ?? null;
const initialCatalog = await loadCatalogListing({ page: 1, limit: 24, category: slug });
const categoryName =
  categoryNameFromDb ||
  landingCategoryNames[slug] ||
  initialCatalog.meta?.categoryTypeTree.find((item) => item.slug === slug)?.category ||
  "";

if (!categoryName || initialCatalog.total === 0) {
  return Astro.redirect("/catalog");
}

const pageTitle = normalizeSeoText(categorySeo?.metaTitle ?? categoryName);
const pageDescription = truncateSeoDescription(categorySeo?.metaDescription ?? categorySeo?.description ?? `Товары категории: ${categoryName}.`);
const pageKeywords = buildKeywordsFromTitleAndDescription(pageTitle, pageDescription);
---

<!doctype html>
<html lang="ru">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>{pageTitle}</title>
    <link rel="icon" type="image/png" href="/icons/climatrade-app-icon.png" />
    <link rel="apple-touch-icon" href="/icons/icon-192.png" />
    <link rel="manifest" href="/manifest.webmanifest" />
    <meta name="theme-color" content="#ffffff" />
    <meta name="description" content={pageDescription} />
    <meta name="keywords" content={pageKeywords} />
    <meta property="og:title" content={pageTitle} />
    <meta property="og:description" content={pageDescription} />
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      href="https://fonts.googleapis.com/css2?family=Cormorant+Garamond:wght@400;500&family=DM+Sans:wght@400;500&family=Jaldi:wght@400;700&family=JetBrains+Mono:wght@400&family=Manrope:wght@200;400;500&display=swap"
      rel="stylesheet"
    />
  </head>
  <body>
    <GlobalPreloader />
    <CatalogPage
      client:load
      initialProducts={initialCatalog.items}
      initialMeta={initialCatalog.meta}
      initialTotal={initialCatalog.total}
      initialTotalAll={initialCatalog.totalAll}
      initialHasMore={initialCatalog.hasMore}
      initialLimit={initialCatalog.limit}
      initialCategory={categoryName}
    />
  </body>
</html>
