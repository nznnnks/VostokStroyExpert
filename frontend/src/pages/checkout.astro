---
import { CheckoutPage } from "../components/CheckoutPage";
import GlobalPreloader from "../components/GlobalPreloader.astro";
import { buildKeywordsFromTitleAndDescription, normalizeSeoText, truncateSeoDescription } from "../lib/seo";
import "../styles/global.css";

export const prerender = false;

const pageTitle = normalizeSeoText("Оформление заказа");
const pageDescription = truncateSeoDescription("Оформление заказа и выбор способа оплаты.");
const pageKeywords = buildKeywordsFromTitleAndDescription(pageTitle, pageDescription);
---

<!doctype html>
<html lang="ru">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>{pageTitle}</title>
    <link rel="icon" type="image/png" href="/icons/climatrade-app-icon.png" />
    <link rel="apple-touch-icon" href="/icons/icon-192.png" />
    <link rel="manifest" href="/manifest.webmanifest" />
    <meta name="theme-color" content="#ffffff" />
    <meta name="description" content={pageDescription} />
    <meta name="keywords" content={pageKeywords} />
    <meta property="og:title" content={pageTitle} />
    <meta property="og:description" content={pageDescription} />
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      href="https://fonts.googleapis.com/css2?family=Cormorant+Garamond:wght@400;500&family=DM+Sans:wght@400;500&family=Jaldi:wght@400;700&family=JetBrains+Mono:wght@400&family=Manrope:wght@200;400;500&display=swap"
      rel="stylesheet"
    />
  </head>
  <body>
    <GlobalPreloader />
    <CheckoutPage client:load />
  </body>
</html>
