---
import "../../styles/global.css";
import SiteHeader from "../../components/SiteHeader";
import SiteFooter from "../../components/SiteFooter";
import { loadNewsPostBySlug, loadNewsPosts } from "../../lib/backend-api";
import GlobalPreloader from "../../components/GlobalPreloader.astro";
import { buildKeywordsFromTitleAndDescription, normalizeSeoText, truncateSeoDescription } from "../../lib/seo";

export const prerender = false;

const slug = Astro.params.slug ?? "";
const post = await loadNewsPostBySlug(slug);
const allPosts = await loadNewsPosts();
const relatedPosts = allPosts.filter((item) => item.slug !== slug).slice(0, 3);

const pageTitle = normalizeSeoText(post?.metaTitle ?? post?.title ?? "Άνβνώρϋ");
const pageDescription = truncateSeoDescription(post?.metaDescription ?? post?.excerpt ?? "Άνβνώρη ξνλούμηη η νρπύώκη.");
const pageKeywords = buildKeywordsFromTitleAndDescription(pageTitle, pageDescription);

const formatRelativePublication = (value?: string | null) => {
  if (!value) {
    return post?.dateLabel ?? "βÄî";
  }

  const diffMs = Date.now() - new Date(value).getTime();
  if (!Number.isFinite(diffMs) || diffMs < 0) return "―²–Ψ–Μ―¨–Κ–Ψ ―΅―²–Ψ";

  const diffMinutes = Math.max(0, Math.floor(diffMs / 60000));
  if (diffMinutes < 1) return "―²–Ψ–Μ―¨–Κ–Ψ ―΅―²–Ψ";
  if (diffMinutes < 60) return `${diffMinutes} ${diffMinutes === 1 ? "–Φ–Η–Ϋ―É―²―É" : diffMinutes < 5 ? "–Φ–Η–Ϋ―É―²―΄" : "–Φ–Η–Ϋ―É―²"} –Ϋ–Α–Ζ–Α–¥`;

  const diffHours = Math.floor(diffMinutes / 60);
  if (diffHours < 24) return `${diffHours} ${diffHours === 1 ? "―΅–Α―¹" : diffHours < 5 ? "―΅–Α―¹–Α" : "―΅–Α―¹–Ψ–≤"} –Ϋ–Α–Ζ–Α–¥`;

  const diffDays = Math.floor(diffHours / 24);
  return `${diffDays} ${diffDays === 1 ? "–¥–Β–Ϋ―¨" : diffDays < 5 ? "–¥–Ϋ―è" : "–¥–Ϋ–Β–Ι"} –Ϋ–Α–Ζ–Α–¥`;
};
---

<!doctype html>
<html lang="ru">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>{pageTitle}</title>
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <meta name="description" content={pageDescription} />
    <meta name="keywords" content={pageKeywords} />
    <meta property="og:title" content={pageTitle} />
    <meta property="og:description" content={pageDescription} />
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      href="https://fonts.googleapis.com/css2?family=Cormorant+Garamond:wght@400;500&family=DM+Sans:wght@400;500&family=Jaldi:wght@400;700&family=JetBrains+Mono:wght@400&family=Manrope:wght@200;400;500&display=swap"
      rel="stylesheet"
    />
  </head>
  <body>
    <GlobalPreloader />
    <main class="bg-white text-[#111] [font-family:DM_Sans,Manrope,'Liberation_Sans',sans-serif]">
      <SiteHeader client:load />
      <section class="px-4 py-8 md:px-10 md:py-14">
        <article class="mx-auto max-w-[1320px]">
          <p class="breadcrumb-nav uppercase tracking-[1.5px] text-[#7a7a75] [font-family:Jaldi,'JetBrains_Mono',monospace]">
            <a href="/" class="hover:text-[#111]">–™–Μ–Α–≤–Ϋ–Α―è</a>
            <span class="mx-2 text-[#b5b2ab]">/</span>
            <a href="/news" class="hover:text-[#111]">–ù–Ψ–≤–Ψ―¹―²–Η</a>
            <span class="mx-2 text-[#b5b2ab]">/</span>
            <span>{post?.category ?? "–ù–Ψ–≤–Ψ―¹―²―¨"}</span>
          </p>
          <h1 class="mt-6 max-w-[900px] break-words text-[clamp(2.1rem,8vw,5.15rem)] leading-[0.94] [font-family:'Cormorant_Garamond',serif] md:mt-8 xl:max-w-[1040px]">{post?.title ?? "–€–Α―²–Β―Ä–Η–Α–Μ –Ϋ–Β –Ϋ–Α–Ι–¥–Β–Ϋ"}</h1>
          {post ? (
            <>
              {post.image ? <img src={post.image} alt="" aria-hidden="true" width="1200" height="760" class="mt-7 aspect-[16/9] max-h-[520px] w-full object-cover md:mt-10 lg:max-h-[560px] 2xl:max-h-[720px]" /> : null}
              <div class="mt-6 md:mt-8">
                <div class="grid gap-4 md:grid-cols-[minmax(0,1fr)_auto] md:items-start">
                  <div>
                    <p class="text-[12px] uppercase tracking-[1.8px] text-[#8b8a84] [font-family:Jaldi,'JetBrains_Mono',monospace]">{post.category}</p>
                    <h2 class="mt-2 max-w-[780px] text-[clamp(1.85rem,4.2vw,3.15rem)] leading-[0.96] [font-family:'Cormorant_Garamond',serif]">{post.title}</h2>
                  </div>
                  <time datetime={post.publishedAt ?? post.createdAt} class="text-[15px] text-[#8f8f89] md:pt-8 md:text-[18px]">
                    {formatRelativePublication(post.publishedAt ?? post.createdAt)}
                  </time>
                </div>
                <p class="mt-4 max-w-[860px] text-[16px] leading-[1.55] text-[#5d5d58] md:text-[19px]">{post.excerpt}</p>
              </div>
              {post.images?.length > 1 ? (
                <div class="mt-4 grid gap-4 sm:grid-cols-2 lg:grid-cols-3">
                  {post.images.slice(1).map((image) => (
                    <img src={image} alt="" aria-hidden="true" width="800" height="520" class="aspect-[4/3] w-full object-cover" loading="lazy" decoding="async" />
                  ))}
                </div>
              ) : null}
              <div class="mt-7 space-y-5 text-[17px] leading-[1.65] text-[#5d5d58] md:mt-10 md:space-y-8 md:text-[24px] md:leading-[1.8]">
                {post.content.map((paragraph) => (
                  <p>{paragraph}</p>
                ))}
              </div>
            </>
          ) : (
            <div class="mt-7 border border-[#e8e3db] px-5 py-8 text-[17px] text-[#5d5d58] md:mt-10 md:px-8 md:py-12 md:text-[20px]">–€–Α―²–Β―Ä–Η–Α–Μ –Ϋ–Β –Ϋ–Α–Ι–¥–Β–Ϋ.</div>
          )}
          <div class="mt-7 md:mt-10">
            <a href="/news" class="inline-flex h-12 items-center justify-center border border-[#111] px-6 text-[13px] uppercase tracking-[1.2px] text-[#111] md:h-14 md:px-8 md:text-[14px] md:tracking-[1.5px] [font-family:Jaldi,'JetBrains_Mono',monospace]">
              –ù–Α–Ζ–Α–¥ –Κ –±–Μ–Ψ–≥―É
            </a>
          </div>
        </article>
        {relatedPosts.length > 0 ? (
          <section class="mx-auto mt-12 max-w-[1320px] border-t border-[#ded8cf] pt-8 md:mt-16 md:pt-10">
            <div class="flex flex-col gap-3 md:flex-row md:items-end md:justify-between">
              <div>
                <p class="text-[12px] uppercase tracking-[2px] text-[#9a9993] [font-family:Jaldi,'JetBrains_Mono',monospace]">–î―Ä―É–≥–Η–Β –Φ–Α―²–Β―Ä–Η–Α–Μ―΄</p>
                <h2 class="mt-2 text-[clamp(2rem,4.2vw,4rem)] leading-[0.95] [font-family:'Cormorant_Garamond',serif]">–ï―â–Β –Η–Ζ –±–Μ–Ψ–≥–Α</h2>
              </div>
              <a href="/news" class="text-[13px] uppercase tracking-[1.5px] text-[#111] [font-family:Jaldi,'JetBrains_Mono',monospace]">–£―¹–Β –Ϋ–Ψ–≤–Ψ―¹―²–Η</a>
            </div>
            <div class="mt-7 grid gap-5 md:grid-cols-3 md:gap-6">
              {relatedPosts.map((item) => (
                <article class="group overflow-hidden border border-[#e8e3db] bg-white transition duration-500 hover:-translate-y-1 hover:shadow-[0_18px_42px_rgba(0,0,0,0.08)]">
                  <a href={`/news/${item.slug}`} class="flex h-full flex-col">
                    {item.image ? <img src={item.image} alt="" aria-hidden="true" width="800" height="520" class="aspect-[16/10] w-full object-cover transition duration-700 group-hover:scale-[1.025]" loading="lazy" decoding="async" /> : null}
                    <div class="flex flex-1 flex-col bg-[#e1ddd6] px-4 py-4 md:px-5">
                      <div class="grid grid-cols-[minmax(0,1fr)_auto] gap-3">
                        <p class="text-[11px] uppercase tracking-[1.5px] text-[#8b8a84] [font-family:Jaldi,'JetBrains_Mono',monospace]">{item.category}</p>
                        <time datetime={item.publishedAt ?? item.createdAt} class="text-[12px] leading-none text-[#8f8f89]">{formatRelativePublication(item.publishedAt ?? item.createdAt)}</time>
                      </div>
                      <h3 class="mt-3 text-[clamp(1.55rem,2.4vw,2.25rem)] leading-[0.95] [font-family:'Cormorant_Garamond',serif]">{item.title}</h3>
                      <p class="mt-3 line-clamp-3 text-[14px] leading-5 text-[#5d5d58] md:text-[15px]">{item.excerpt}</p>
                      <span class="mt-auto inline-flex pt-5 text-[12px] uppercase tracking-[1.5px] text-[#111] [font-family:Jaldi,'JetBrains_Mono',monospace]">–ß–Η―²–Α―²―¨</span>
                    </div>
                  </a>
                </article>
              ))}
            </div>
          </section>
        ) : null}
      </section>
      <SiteFooter />
    </main>
  </body>
</html>
